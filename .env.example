PORT=3000

# Mongo Atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=lufious

# Firebase Admin (base64 of service account JSON) — used for idToken verify + FCM push
FIREBASE_SERVICE_ACCOUNT=

# AWS S3 — image upload storage (signed PUT URLs)
AWS_REGION=ap-south-1
S3_BUCKET=lufious-uploads
# Local dev only: provide keys if not running on EC2 with IAM role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Third-party APIs
OPENWEATHER_KEY=
PLANTNET_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-1.5-flash

# Rate limiter
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron job auth
CRON_SECRET=
