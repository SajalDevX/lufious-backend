PORT=3000

# Mongo Atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=lufious

# Firebase Admin (base64 of service account JSON)
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_STORAGE_BUCKET=lufious.appspot.com

# Third-party APIs (Phase 3+)
OPENWEATHER_KEY=
PLANTNET_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-1.5-flash

# Rate limiter (Phase 1+)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron job auth (Phase 7)
CRON_SECRET=
