# Copy to terraform.tfvars and fill in. terraform.tfvars is git-ignored.

region = "ap-south-1"
project = "lufious"
env     = "dev"

# Restrict to your laptop IP for safety, e.g. "203.0.113.42/32"
ssh_cidr = "0.0.0.0/0"

# Paste contents of ~/.ssh/id_ed25519.pub (single line)
ssh_public_key = "ssh-ed25519 AAAA... your-laptop"

# Backend will pull from this on first boot
github_repo_url = "https://github.com/SajalDevX/lufious-backend.git"
github_branch   = "main"

# --- Secrets ---
mongodb_uri                  = "mongodb+srv://USER:PASS@cluster0.hqsdqth.mongodb.net/?retryWrites=true&w=majority"
mongodb_db                   = "lufious"
firebase_service_account_b64 = "ewogICJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCI..."  # base64 -w0 of service account JSON
openweather_key              = ""
plantnet_key                 = ""
openrouter_api_key           = ""
openrouter_model             = "google/gemini-1.5-flash"
cron_secret                  = ""  # openssl rand -hex 32
upstash_redis_rest_url       = ""
upstash_redis_rest_token     = ""
